{
	"name": "wsmc",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"seed": "wrangler d1 execute wsmc-db --local --file=scripts/seed.sql",
		"seed:remote": "wrangler d1 execute wsmc-db --remote --file=scripts/seed.sql"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260312.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"drizzle-kit": "^0.31.9",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"wrangler": "^4.72.0"
	},
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"drizzle-orm": "^0.45.1"
	}
}
